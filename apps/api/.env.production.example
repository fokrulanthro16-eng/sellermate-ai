# ── Production Environment Template ───────────────────────────────────────────
# Copy to .env and fill all required (*) values before deploying.
# DO NOT commit .env to version control.

# ── Application ────────────────────────────────────────────────────────────────
APP_ENV=production                           # * must be "production"
APP_SECRET_KEY=REPLACE_WITH_64_CHAR_HEX     # * generate: python -c "import secrets; print(secrets.token_hex(32))"
APP_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── PostgreSQL ──────────────────────────────────────────────────────────────────
# In Docker Compose, host is the service name "db"
DATABASE_URL=postgresql+asyncpg://sellermate:REPLACE_PG_PASSWORD@db:5432/sellermate  # *
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ── Redis ───────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0               # * adjust host in production

# ── CORS ────────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://yourdomain.com       # * replace with your domain

# ── Docker DB password (used by docker-compose.prod.yml) ──────────────────────
DB_PASSWORD=REPLACE_PG_PASSWORD              # * must match DATABASE_URL password

# ── AI Providers (at least one required for AI features) ──────────────────────
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Cloudflare R2 / AWS S3 (required for file uploads) ───────────────────────
S3_BUCKET_NAME=sellermate-uploads
S3_REGION=auto
S3_ACCESS_KEY=                               # *
S3_SECRET_KEY=                               # *
S3_ENDPOINT_URL=                             # R2: https://<account_id>.r2.cloudflarestorage.com

# ── WhatsApp Cloud API ────────────────────────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# ── Courier Integrations ───────────────────────────────────────────────────────
PATHAO_CLIENT_ID=
PATHAO_CLIENT_SECRET=
STEADFAST_API_KEY=
STEADFAST_SECRET_KEY=
REDX_API_KEY=

# ── Payment Integrations ───────────────────────────────────────────────────────
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=
BKASH_APP_KEY=
BKASH_APP_SECRET=
NAGAD_MERCHANT_ID=
NAGAD_MERCHANT_NUMBER=

# ── Marketplace Integrations ───────────────────────────────────────────────────
FACEBOOK_PAGE_ID=
FACEBOOK_ACCESS_TOKEN=
DARAZ_APP_KEY=
DARAZ_SIGNATURE=
SHOPIFY_SHOP_URL=
SHOPIFY_ACCESS_TOKEN=

# ── Notification Channels ─────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMS_API_KEY=
SMS_SENDER_ID=

# ── Webhook Secrets ───────────────────────────────────────────────────────────
PATHAO_WEBHOOK_SECRET=
STEADFAST_WEBHOOK_SECRET=
REDX_WEBHOOK_SECRET=
SSLCOMMERZ_WEBHOOK_SECRET=
BKASH_WEBHOOK_SECRET=
NAGAD_WEBHOOK_SECRET=
DARAZ_WEBHOOK_SECRET=
SHOPIFY_WEBHOOK_SECRET=

# ── OTP ───────────────────────────────────────────────────────────────────────
OTP_EXPIRE_MINUTES=10
OTP_LENGTH=6

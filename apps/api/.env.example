# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
APP_SECRET_KEY=change-this-to-a-random-64-char-hex-string
APP_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://sellermate:password@localhost:5432/sellermate
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Cloudflare R2 / AWS S3 ────────────────────────────────────────────────────
S3_BUCKET_NAME=sellermate-uploads
S3_REGION=auto
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
# Leave empty for AWS; set for R2: https://<account_id>.r2.cloudflarestorage.com
S3_ENDPOINT_URL=

# ── AI Providers (priority: Gemini → OpenAI → Anthropic → Mock) ──────────────
# Leave all blank to use the built-in mock AI (no real key required)
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── WhatsApp Cloud API ────────────────────────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# ── Courier Integrations (Phase 5) ────────────────────────────────────────────
# Leave blank to use mock providers
PATHAO_CLIENT_ID=
PATHAO_CLIENT_SECRET=
STEADFAST_API_KEY=
STEADFAST_SECRET_KEY=
REDX_API_KEY=

# ── Payment Integrations (Phase 5) ────────────────────────────────────────────
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=
BKASH_APP_KEY=
BKASH_APP_SECRET=
NAGAD_MERCHANT_ID=
NAGAD_MERCHANT_NUMBER=

# ── Marketplace Integrations (Phase 5) ────────────────────────────────────────
FACEBOOK_PAGE_ID=
FACEBOOK_ACCESS_TOKEN=
DARAZ_APP_KEY=
DARAZ_SIGNATURE=
SHOPIFY_SHOP_URL=
SHOPIFY_ACCESS_TOKEN=

# ── Notification Channels (Phase 5) ───────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMS_API_KEY=
SMS_SENDER_ID=

# ── Webhook Secrets (Phase 7) — used to verify HMAC signatures from providers ─
# Leave blank in mock/dev mode — signature verification is skipped when empty
PATHAO_WEBHOOK_SECRET=
STEADFAST_WEBHOOK_SECRET=
REDX_WEBHOOK_SECRET=
SSLCOMMERZ_WEBHOOK_SECRET=
BKASH_WEBHOOK_SECRET=
NAGAD_WEBHOOK_SECRET=
DARAZ_WEBHOOK_SECRET=
SHOPIFY_WEBHOOK_SECRET=

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ── OTP (phone verification) ──────────────────────────────────────────────────
OTP_EXPIRE_MINUTES=10
OTP_LENGTH=6

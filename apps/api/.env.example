# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
APP_SECRET_KEY=change-this-to-a-random-64-char-hex-string
APP_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://sellermate:password@localhost:5432/sellermate
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Cloudflare R2 / AWS S3 ────────────────────────────────────────────────────
S3_BUCKET_NAME=sellermate-uploads
S3_REGION=auto
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
# Leave empty for AWS; set for R2: https://<account_id>.r2.cloudflarestorage.com
S3_ENDPOINT_URL=

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── WhatsApp Cloud API ────────────────────────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ── OTP (phone verification) ──────────────────────────────────────────────────
OTP_EXPIRE_MINUTES=10
OTP_LENGTH=6
